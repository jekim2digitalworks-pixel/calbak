# ── Supabase ─────────────────────────────────────────────
# 클라이언트(브라우저) 노출 OK — RLS로 보호
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 절대 클라이언트에 노출 금지 (특권 작업: Drive 팬아웃 등)
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (Drive + Calendar) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
# 요청 스코프(참고): openid email profile drive.file calendar.events

# ── 보안 ─────────────────────────────────────────────────
# refresh token 암호화 키 (32바이트 권장). 예: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ── 앱 ───────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
